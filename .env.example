# ============================================
# Shiori Backup System - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to git - it contains secrets!
#
# Quick Start:
# 1. Generate encryption key: openssl rand -base64 32
# 2. Configure rclone: cp backup/rclone.conf.example backup/rclone.conf
# 3. Set BACKUP_RCLONE_DESTINATIONS to your cloud storage
# 4. docker-compose up -d backup
# ============================================

# ============================================
# REQUIRED: Encryption
# ============================================
# Generate a secure encryption key for backup archives
# Run: openssl rand -base64 32
BACKUP_ENCRYPTION_KEY=change-this-to-a-secure-random-key

# ============================================
# REQUIRED: Cloud Storage Destinations
# ============================================
# Comma-separated list of rclone destinations
# Format: remote:path (e.g., r2:bucket/shiori-backups)
# The remote name must match a section in backup/rclone.conf
#
# Examples:
# BACKUP_RCLONE_DESTINATIONS=r2:my-bucket/shiori-backups
# BACKUP_RCLONE_DESTINATIONS=r2:bucket1/shiori,s3:bucket2/shiori,b2:bucket3/shiori
BACKUP_RCLONE_DESTINATIONS=

# ============================================
# OPTIONAL: Backup Schedule
# ============================================
# Cron expression for automatic backups (UTC time)
# Default: Daily at 2:00 AM UTC
#
# Common examples:
#   0 2 * * *      - Daily at 2 AM
#   0 */6 * * *    - Every 6 hours
#   0 3 * * 0      - Weekly on Sunday at 3 AM
#   0 0 1 * *      - Monthly on 1st at midnight
BACKUP_SCHEDULE=0 2 * * *

# Run a backup immediately when container starts
# Useful for testing or one-time backups
BACKUP_RUN_ON_START=false

# ============================================
# OPTIONAL: Retention Policy
# ============================================
# Number of days to keep backups (0 = keep forever)
# Applies to both local and cloud storage
BACKUP_RETENTION_DAYS=30

# Delete local backup after successful cloud upload
# WARNING: Only enable if you're confident in your cloud storage
BACKUP_DELETE_LOCAL_AFTER_UPLOAD=false

# ============================================
# OPTIONAL: Webhook Notifications
# ============================================
# Send JSON notifications on backup success/failure
# Supports Slack, Discord, or any webhook endpoint
#
# Slack example: https://hooks.slack.com/services/T00/B00/XXXX
# Discord example: https://discord.com/api/webhooks/000/xxx
# ntfy example: https://ntfy.sh/my-topic
BACKUP_WEBHOOK_URL=

# ============================================
# OPTIONAL: Email Notifications (SMTP)
# ============================================
# Send email alerts on backup success/failure
# Works with Gmail, Outlook, or any SMTP server
#
# Gmail setup:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your-email@gmail.com
#   SMTP_PASSWORD=your-app-specific-password
#   SMTP_TO=admin@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TO=

# ============================================
# OPTIONAL: Logging
# ============================================
# Log level: DEBUG, INFO, WARNING, ERROR
# Use DEBUG for troubleshooting
LOG_LEVEL=INFO

# ============================================
# ADVANCED: Database Configuration
# ============================================
# The backup system auto-detects database type from environment
# You usually don't need to change these if using docker-compose

# Option 1: PostgreSQL connection URL (used by docker-compose.yml)
# SHIORI_DATABASE_URL=postgres://shiori:shiori@postgres/shiori?sslmode=disable

# Option 2: MySQL/MariaDB connection URL
# SHIORI_DATABASE_URL=mysql://user:pass@host:3306/shiori?charset=utf8mb4

# Option 3: SQLite data directory (if not using docker-compose postgres)
# SHIORI_DATA_DIR=/srv/shiori

# ============================================
# EXAMPLE CONFIGURATIONS
# ============================================

# --- Minimal Local-Only Setup ---
# BACKUP_ENCRYPTION_KEY=$(openssl rand -base64 32)
# BACKUP_RCLONE_DESTINATIONS=""
# BACKUP_RETENTION_DAYS=7

# --- Cloudflare R2 Setup ---
# BACKUP_ENCRYPTION_KEY=$(openssl rand -base64 32)
# BACKUP_RCLONE_DESTINATIONS=r2:my-bucket/shiori-backups
# BACKUP_RETENTION_DAYS=30
# (Also configure backup/rclone.conf with R2 credentials)

# --- AWS S3 Setup ---
# BACKUP_ENCRYPTION_KEY=$(openssl rand -base64 32)
# BACKUP_RCLONE_DESTINATIONS=s3:my-backup-bucket/shiori
# BACKUP_RETENTION_DAYS=90
# (Also configure backup/rclone.conf with AWS credentials)

# --- Multi-Cloud Redundancy ---
# BACKUP_ENCRYPTION_KEY=$(openssl rand -base64 32)
# BACKUP_RCLONE_DESTINATIONS=r2:bucket1/shiori,s3:bucket2/shiori,b2:bucket3/shiori
# BACKUP_RETENTION_DAYS=30
# (Also configure backup/rclone.conf with all three remotes)

# --- Development/Testing ---
# BACKUP_ENCRYPTION_KEY=test-key-not-for-production
# BACKUP_RCLONE_DESTINATIONS=""
# BACKUP_SCHEDULE=0 */1 * * *  # Every hour for testing
# BACKUP_RETENTION_DAYS=1
# LOG_LEVEL=DEBUG
