# ============================================
# Shiori Backup Configuration
# ============================================

# Required: Encryption key for backup archives
# Generate with: openssl rand -base64 32
BACKUP_ENCRYPTION_KEY=your-encryption-key-here

# Required: Cloud storage destinations (comma-separated)
# Format: remote:path (e.g., r2:my-bucket/shiori-backups,s3:my-bucket/shiori)
BACKUP_RCLONE_DESTINATIONS=r2:my-bucket/shiori-backups

# ============================================
# Backup Schedule & Retention
# ============================================

# Cron expression for backup schedule (default: daily at 2 AM UTC)
BACKUP_SCHEDULE=0 2 * * *

# Number of days to retain backups (0 = disable cleanup)
BACKUP_RETENTION_DAYS=30

# Run backup immediately on container startup
BACKUP_RUN_ON_START=false

# Delete local backup after successful cloud upload
BACKUP_DELETE_LOCAL_AFTER_UPLOAD=false

# ============================================
# Shiori Database Configuration
# ============================================

# Option 1: PostgreSQL/MySQL connection URL (same as Shiori)
# SHIORI_DATABASE_URL=postgres://shiori:shiori@postgres/shiori?sslmode=disable

# Option 2: SQLite mode - path to Shiori data directory
# SHIORI_DATA_DIR=/shiori-data

# ============================================
# Notification Settings (Optional)
# ============================================

# Webhook URL for backup notifications
# BACKUP_WEBHOOK_URL=https://hooks.slack.com/services/...

# SMTP settings for email notifications
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_TO=admin@example.com

# ============================================
# Logging
# ============================================

LOG_LEVEL=INFO
